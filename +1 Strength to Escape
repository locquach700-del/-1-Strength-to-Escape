-- DANH SÁCH TẠ CHUẨN ĐƯỢC ĐỒNG BỘ THEO WINS VÀ TÊN TRONG EXPLORER
local WeightDatabase = {
    {Name = "Wood Weight",      Wins = 0},
    {Name = "Weight",           Wins = 1},
    {Name = "Stone Weight",     Wins = 5},
    {Name = "Gold Weight",      Wins = 20},
