    {Name = "Hacker Weight",    Wins = 45000},
    {Name = "Blackhole Weight", Wins = 150000},
    {Name = "Magma Weight",     Wins = 500000}, 
    {Name = "Void Weight",      Wins = 1000000}, 
    {Name = "Diamond Weight",   Wins = 5000000},
    {Name = "Demon Weight",     Wins = 25000000},
    {Name = "Celestial Weight", Wins = 100000000},
    {Name = "Infinity Weight",  Wins = 999999999}
}

local function GetCurrentWins()
    local leaderstats = Player:FindFirstChild("leaderstats")
    if leaderstats then
        local winsValue = leaderstats:FindFirstChild("Wins") or leaderstats:FindFirstChild("Win")
        if winsValue then return winsValue.Value end
    end
    return 0
end

-- THUẬT TOÁN ÉP MUA CƯỠNG CHẾ (KHÔNG CẦN DỊCH CHUYỂN)
local function ForcePurchaseBestWeight()
    local currentWins = GetCurrentWins()
    local bestWeight = nil
    
    -- Tìm ra cây tạ xịn nhất dựa trên số Wins hiện có
    for _, weight in ipairs(WeightDatabase) do
        if currentWins >= weight.Wins then
            bestWeight = weight.Name
        end
    end
    
    -- Nếu tìm ra, nã liên tục 5 lệnh mua cùng lúc để ép server mở khóa
    if bestWeight then
        pcall(function()
            for i = 1, 5 do
                task.spawn(function()
                    BuyWeightRemote:FireServer(bestWeight)
                end)
            end
        end)
    end
end

-- BỘ LỌC ẨN KHUNG ĐEN VÀ TẮT TIẾNG ERROR
local function GodSpeedClean()
    pcall(function()
        for _, sound in pairs(SoundService:GetDescendants()) do
            if sound:IsA("Sound") then
                local sName = sound.Name:lower()
                if sName == "error" or string.find(sName, "punch") or string.find(sName, "hit") or string.find(sName, "gain") then
                    sound.Volume = 0
                    if sound.Playing then sound.Playing = false end
                end
            end
        end
        for _, v in pairs(PlayerGui:GetChildren()) do
            for _, child in pairs(v:GetDescendants()) do
                if child:IsA("TextLabel") or child:IsA("TextBox") then
                    if string.find(child.Text, "Break") or string.find(child.Text, "Stage") or child.TextColor3 == Color3.fromRGB(255, 0, 0) then
                        child.Visible = false
                        local parent = child.Parent
                        if parent and (parent:IsA("Frame") or parent:IsA("ImageLabel")) then
                            parent.Visible = false
                            if parent.Parent and parent.Parent:IsA("Frame") then
                                parent.Parent.Visible = false
                            end
                        end
                    end
                end
            end
        end
    end)
end

